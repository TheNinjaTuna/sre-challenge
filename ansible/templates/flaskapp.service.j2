[Unit]
Description=Warpnet Flask App
After=network.target

[Service]
User=flaskapp
Group=flaskapp

WorkingDirectory=/opt/flaskapp/app

Environment="APP_SECRET={{ APP_SECRET }}"

ExecStart=/opt/flaskapp/venv/bin/flask --app application run --host=0.0.0.0

Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target